---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const roles = [
  {
    title: "Research & Monitoring",
    desc: "Analiza ofert operatorów i flagowanie mechanizmów, które mogą być szkodliwe dla użytkowników. Tworzenie raportów etycznych.",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
  },
  {
    title: "Edukacja & Content",
    desc: "Pisanie artykułów do Bazy Wiedzy, tworzenie grafik edukacyjnych i prowadzenie warsztatów z higieny cyfrowej.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
  },
  {
    title: "Wsparcie Prawne",
    desc: "Pomoc w interpretacji regulaminów i wsparcie osób, które czują się poszkodowane przez nieuczciwe praktyki rynkowe.",
    icon: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"
  }
];
---

<Layout title="Wolontariat | Fundacja Znaj Granice">
  <main class="bg-white min-h-screen">
    
    <section class="bg-slate-900 py-24 px-6 text-white relative overflow-hidden">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-emerald-500/5 -skew-x-12 translate-x-1/4"></div>
      <div class="max-w-4xl mx-auto relative z-10">
        <a href="/" class="text-emerald-500 hover:text-emerald-400 transition-colors font-bold uppercase tracking-widest text-sm flex items-center gap-2 mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Powrót do strony głównej
        </a>
        <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase mb-6 leading-none">
          ZOSTAŃ <span class="text-emerald-500">STRAŻNIKIEM</span> STANDARDÓW
        </h1>
        <p class="text-slate-400 text-xl max-w-2xl font-medium leading-relaxed">
          Nie walczymy z branżą – wspieramy ją w byciu lepszą. Dołącz do nas i pomóż nam flagować nieprawidłowości oraz edukować społeczeństwo.
        </p>
      </div>
    </section>

    <section class="py-24 px-6 -mt-12 relative z-20">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
          {roles.map(role => (
            <div class="bg-white p-10 rounded-[3rem] shadow-2xl border border-slate-100 hover:border-emerald-500 transition-all duration-500 group">
              <div class="w-14 h-14 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-emerald-500 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={role.icon} />
                </svg>
              </div>
              <h3 class="text-2xl font-black uppercase tracking-tight text-slate-900 mb-4">{role.title}</h3>
              <p class="text-slate-600 font-medium leading-relaxed">{role.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 px-6 bg-slate-50">
      <div class="max-w-6xl mx-auto">
        <div class="bg-slate-900 rounded-[4rem] overflow-hidden flex flex-col lg:flex-row shadow-3xl">
          <div class="lg:w-1/2 p-12 md:p-20">
            <h2 class="text-4xl font-black text-white uppercase tracking-tighter mb-8 leading-tight">
              Co zyskujesz jako <br/><span class="text-emerald-500">Wolontariusz?</span>
            </h2>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="w-6 h-6 bg-emerald-500 rounded-full shrink-0 flex items-center justify-center mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                  <p class="text-white font-bold uppercase text-sm tracking-widest">Realny wpływ</p>
                  <p class="text-slate-400 text-sm">Twoje raporty realnie wpływają na to, jak operatorzy komunikują swoje usługi.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-6 h-6 bg-emerald-500 rounded-full shrink-0 flex items-center justify-center mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                  <p class="text-white font-bold uppercase text-sm tracking-widest">Wiedza ekspercka</p>
                  <p class="text-slate-400 text-sm">Dostęp do szkoleń z psychologii gier, prawa i bezpieczeństwa cyfrowego.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-6 h-6 bg-emerald-500 rounded-full shrink-0 flex items-center justify-center mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                  <p class="text-white font-bold uppercase text-sm tracking-widest">Zaświadczenie</p>
                  <p class="text-slate-400 text-sm">Wystawiamy oficjalne zaświadczenia o wolontariacie, cenione przez pracodawców.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="lg:w-1/2 bg-emerald-600 flex items-center justify-center p-12 text-center">
            <div>
              <div class="inline-block p-4 bg-white/10 rounded-full mb-8">
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              </div>
              <h3 class="text-3xl font-black text-white uppercase mb-6 leading-tight italic">"Pomaganie to nie walka, <br/>to budowanie lepszych zasad."</h3>
              <p class="text-emerald-100 font-medium max-w-sm mx-auto">Dołącz do zespołu 40+ wolontariuszy, którzy dbają o higienę cyfrową w Polsce.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 bg-white">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter text-slate-900 mb-6">Chcę <span class="text-emerald-600">pomóc!</span></h2>
        <p class="text-slate-500 font-medium mb-12">Wypełnij krótki formularz – odezwiemy się w ciągu 48 godzin, aby porozmawiać o tym, jak najlepiej wykorzystać Twój talent.</p>
        
        <form class="text-left grid gap-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 ml-4">Imię i Nazwisko</label>
              <input type="text" placeholder="Jan Kowalski" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:border-emerald-500 focus:outline-none transition" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 ml-4">E-mail</label>
              <input type="email" placeholder="jan@kowalski.pl" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:border-emerald-500 focus:outline-none transition" />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 ml-4">W czym czujesz się najlepiej?</label>
            <select class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:border-emerald-500 focus:outline-none transition appearance-none">
              <option>Monitorowanie rynku i flagowanie</option>
              <option>Pisanie artykułów i edukacja</option>
              <option>Prawo i regulaminy</option>
              <option>Social Media / Grafika</option>
              <option>Inne (opisz poniżej)</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 ml-4">Kilka słów o Tobie</label>
            <textarea rows="4" placeholder="Dlaczego chcesz do nas dołączyć?" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:border-emerald-500 focus:outline-none transition"></textarea>
          </div>
          <button type="submit" class="bg-emerald-600 hover:bg-emerald-500 text-white font-black uppercase tracking-widest py-6 rounded-2xl shadow-xl shadow-emerald-200/50 transition-all">
            Wyślij zgłoszenie
          </button>
        </form>
      </div>
    </section>

  </main>
  <Footer />
</Layout>