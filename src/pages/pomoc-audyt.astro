---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Etyczny Skaner | Fundacja Znaj Granice">
  <main class="bg-slate-50 min-h-screen">
    
    <section class="bg-slate-900 py-16 px-6 text-white text-center">
      <div class="max-w-4xl mx-auto">
        <span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest mb-6 inline-block">
          AI Compliance Engine v1.0
        </span>
        <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter mb-4">
          Etyczny <span class="text-emerald-500">Skaner</span> Regulaminów
        </h1>
        <p class="text-slate-400 font-medium max-w-xl mx-auto">
          Wklej treść regulaminu lub opis promocji, aby sprawdzić zgodność ze standardami ochrony użytkownika.
        </p>
      </div>
    </section>

    <section class="py-12 px-6 -mt-8">
      <div class="max-w-5xl mx-auto">
        <div class="grid lg:grid-cols-3 gap-8">
          
          <div class="lg:col-span-2 space-y-6">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100">
              <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4 block ml-2">Treść do analizy</label>
              <textarea 
                id="auditInput"
                class="w-full h-80 p-6 bg-slate-50 border border-slate-100 rounded-3xl focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-all font-medium text-slate-700 leading-relaxed"
                placeholder="Wklej tutaj tekst regulaminu, treść reklamy lub skrypt promocji..."></textarea>
              
              <div class="mt-6 flex gap-4">
                <button id="runAudit" class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white font-black uppercase tracking-widest py-5 rounded-2xl shadow-lg shadow-emerald-200 transition-all flex items-center justify-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                  Uruchom Audyt AI
                </button>
              </div>
            </div>
          </div>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100">
              <h3 class="font-black uppercase tracking-tight text-slate-900 mb-6">Opcje Audytu</h3>
              <div class="space-y-4">
                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                  <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Dla kogo?</p>
                  <p class="font-bold text-slate-900">Operator (Partner)</p>
                </div>
                <div class="p-4 bg-emerald-50 rounded-2xl border border-emerald-100">
                  <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest mb-1">Status Licencji</p>
                  <p class="font-bold text-emerald-900 uppercase italic">Aktywna (B2B)</p>
                </div>
              </div>
            </div>

            <div class="bg-slate-900 p-8 rounded-[2.5rem] text-white shadow-xl relative overflow-hidden">
               <div class="absolute top-0 right-0 p-4 opacity-20">
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
               </div>
               <p class="text-xs font-black uppercase text-emerald-500 mb-2">Tryb Demo</p>
               <p class="text-sm font-medium text-slate-300 mb-4">W wersji bezpłatnej analiza ograniczona do 1000 znaków.</p>
               <a href="/wspieram" class="text-xs font-bold underline hover:text-emerald-400 transition">Kup pełny raport →</a>
            </div>
          </div>

        </div>

        <div id="auditResult" class="mt-12 hidden">
          <div class="bg-white p-10 rounded-[3rem] shadow-2xl border-4 border-emerald-500/20">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
              <h2 class="text-3xl font-black uppercase tracking-tighter">Wynik analizy <span class="text-emerald-500">Fundacji</span></h2>
              <div class="px-6 py-2 bg-emerald-500 text-white rounded-full font-black text-xl">82/100</div>
            </div>
            
            <div class="grid md:grid-cols-2 gap-12">
              <div class="space-y-6">
                <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Znalezione ryzyka</p>
                <div class="bg-red-50 p-6 rounded-2xl border-l-4 border-red-500">
                  <p class="font-bold text-red-900 mb-2 italic">"Tylko dzisiaj! Odbierz bonus albo stracisz okazję!"</p>
                  <p class="text-sm text-red-700">Wykryto mechanizm FOMO. Może skłaniać do ryzykownych zachowań impulsywnych.</p>
                </div>
              </div>
              <div class="space-y-6">
                <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Sugerowana poprawka</p>
                <div class="bg-emerald-50 p-6 rounded-2xl border-l-4 border-emerald-500">
                  <p class="text-sm text-emerald-800 leading-relaxed font-medium text-justify">
                    Zmień sformułowanie na neutralne, np. "Bonus dostępny w dniu dzisiejszym". Usuń element straty ("stracisz okazję"), aby zachować standardy etyczne ochrony gracza.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  // Prosta logika pokazywania wyniku (dla 0-code użytkownika na start)
  const btn = document.getElementById('runAudit');
  const result = document.getElementById('auditResult');

  btn?.addEventListener('click', () => {
    btn.innerHTML = "Analizowanie przez AI...";
    setTimeout(() => {
      result?.classList.remove('hidden');
      btn.innerHTML = "Analiza zakończona";
      window.scrollTo({ top: result?.offsetTop ? result.offsetTop - 50 : 0, behavior: 'smooth' });
    }, 2000);
  });
</script>